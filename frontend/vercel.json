{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/google6a518d32c39b617a.html",
      "dest": "/google6a518d32c39b617a.html"
    },

    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },

    {
      "handle": "filesystem"
    },

    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
